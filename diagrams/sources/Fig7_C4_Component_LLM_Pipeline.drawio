        <mxCell id="10" value="&lt;b style=&quot;color:white&quot;&gt;API Endpoint&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#DCE9F5&quot;&gt;[FastAPI route]&lt;/i&gt;&lt;br&gt;&lt;span style=&quot;color:#E7F0F7;font-size:10px&quot;&gt;Приём триггеров запуска,&lt;br&gt;статус задач, healthcheck&lt;/span&gt;" style="whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#85BBF0;strokeColor=#5D82A8;fontColor=#FFFFFF;fontSize=11;rounded=1;" vertex="1" parent="1"><mxGeometry x="520" y="160" width="620" height="120" as="geometry"/></mxCell>

        <mxCell id="11" value="&lt;b style=&quot;color:white&quot;&gt;Data Loader&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#DCE9F5&quot;&gt;[Python, psycopg2]&lt;/i&gt;&lt;br&gt;&lt;span style=&quot;color:#E7F0F7;font-size:10px&quot;&gt;Выгрузка сырых отзывов и сообщений&lt;br&gt;из Data Lake по фильтрам периода/источника&lt;/span&gt;" style="whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#85BBF0;strokeColor=#5D82A8;fontColor=#FFFFFF;fontSize=11;rounded=1;" vertex="1" parent="1"><mxGeometry x="520" y="320" width="620" height="120" as="geometry"/></mxCell>

