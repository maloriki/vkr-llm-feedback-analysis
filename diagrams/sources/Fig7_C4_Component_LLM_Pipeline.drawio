        <mxCell id="13" value="&lt;b style=&quot;color:white&quot;&gt;Auto-Batcher&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;color:#DCE9F5&quot;&gt;[Python, tiktoken]&lt;/i&gt;&lt;br&gt;&lt;span style=&quot;color:#E7F0F7;font-size:10px&quot;&gt;batch_size = floor(context_window&lt;br&gt;&amp;times; fill_ratio / avg_token_count)&lt;/span&gt;" style="whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#85BBF0;strokeColor=#5D82A8;fontColor=#FFFFFF;fontSize=11;rounded=1;" vertex="1" parent="1"><mxGeometry x="520" y="640" width="620" height="120" as="geometry"/></mxCell>

